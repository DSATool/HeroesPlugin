<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import dsatool.ui.ReactiveComboBox?>
<?import dsatool.ui.ReactiveSpinner?>

<VBox fx:id="root" style="-fx-padding: 4;" spacing="2" xmlns:fx="http://javafx.com/fxml" >
   <VBox fx:id="animalBox" spacing="2" >
      <HBox spacing="2" alignment="CENTER" >
         <Label text="Name: " alignment="CENTER_LEFT" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
         <TextField fx:id="name" prefWidth="150" />
      </HBox>
      <HBox spacing="2" alignment="CENTER_LEFT" >
         <Label text="Tierart: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
         <ReactiveComboBox fx:id="species" editable="true" prefWidth="150" />
      </HBox>
      <HBox spacing="2" alignment="CENTER_LEFT" >
         <Label text="Rasse: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
         <TextField fx:id="race" prefWidth="150" />
      </HBox>
   </VBox>
   <HBox fx:id="modifierBox" spacing="2" >
      <Label text="Modifikator: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="modifier" imin="-999" imax="999" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label text="Start LO: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="start" imin="0" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label text="Erzieherische LO: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="training" imin="0" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label text="Frei LO: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="free" imin="0" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label text="Schulische LO: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="education" imin="0" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label text="Maximale LO: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="max" imin="0" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" >
      <Label maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <Button fx:id="okButton" text="Ok" prefWidth="90" />
      <Button fx:id="cancelButton" text="Abbrechen" prefWidth="90" />
   </HBox>
</VBox>