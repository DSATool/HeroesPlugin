<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import dsatool.ui.ReactiveComboBox?>
<?import dsatool.ui.ReactiveSpinner?>

<VBox fx:id="root" style="-fx-padding: 4;" spacing="2" xmlns:fx="http://javafx.com/fxml" >
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="Ausbildungsziel: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveComboBox fx:id="education" editable="true" prefWidth="120" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="Wildtier: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <CheckBox fx:id="wild" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="Spezialisierung: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveComboBox fx:id="specialization" prefWidth="80" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="Erschwernis: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="modifier" imin="-99" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="benötigte TaP*: " maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="requiredTaP" imin="0" imax="999" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="angesammelte TaP*: " maxWidth="Infinity" minHeight="23" HBox.hgrow="ALWAYS" />
      <Label fx:id="currentTaPLabel" />
   </HBox>
   <HBox spacing="2" alignment="CENTER_LEFT" >
      <Label text="neue TaP*: " />
      <Hyperlink text="(würfeln)" onAction="#talentRoll" />
      <Label maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      <ReactiveSpinner fx:id="newTaP" imin="-99" imax="99" editable="true" prefWidth="80" />
   </HBox>
   <HBox spacing="2" alignment="BOTTOM_LEFT" >
      <Label maxWidth="Infinity" minHeight="35" HBox.hgrow="ALWAYS" />
      <Button fx:id="completeEducationButton" text="Ausbildung abschließen" prefWidth="160" />
   </HBox>
   <HBox spacing="2" alignment="BOTTOM_LEFT" >
      <Label maxWidth="Infinity" minHeight="35" HBox.hgrow="ALWAYS" />
      <Button fx:id="continueEducationButton" text="Ausbildung fortsetzen" prefWidth="150" />
      <Button fx:id="cancelButton" text="Abbrechen" prefWidth="90" />
   </HBox>
</VBox>